# Anna - Telegram Translation + AI Chat Bot
# Fill in your real credentials below

# Get this from @BotFather after creating your bot
BOT_TOKEN=your_telegram_bot_token_here

# Get this from https://aistudio.google.com/apikey (free)
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase (optional - falls back to local JSON if not set)
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_key_here

# Bot owner ID (optional - can also use /setowner command)
BOT_OWNER_ID=your_telegram_user_id_here
